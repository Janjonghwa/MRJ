generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SajuCache {
  id         String   @id @default(uuid())
  hash_key   String   @unique
  llm_result String   @db.Text
  created_at DateTime @default(now())
}
